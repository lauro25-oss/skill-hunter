# ============================================================
# ATS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env.
# ============================================================

# ── Banco de Dados (Google Cloud SQL / PostgreSQL local) ────
DATABASE_URL=postgresql://ats_user:ats_pass@localhost:5432/ats_db

# ── Google Cloud Storage ────────────────────────────────────
GCS_BUCKET_NAME=ats-curriculos
GCS_PROJECT_ID=seu-projeto-gcp
# Caminho local para o JSON da service account (dev) ou deixe vazio no Railway
# (use a variável de ambiente GOOGLE_APPLICATION_CREDENTIALS no painel Railway)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-key.json

# ── Elasticsearch / OpenSearch ──────────────────────────────
ELASTIC_URL=http://localhost:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=changeme
ELASTIC_INDEX=candidates

# ── LLM / Parsing ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Aplicação ───────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-segura-em-producao
ENVIRONMENT=development
# Origens permitidas pelo CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
